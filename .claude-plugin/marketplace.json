    "metadata": {
        "description": "NGA-TC-Team의 Claude Code 플러그인 마켓플레이스. NGA 컨설팅 현장에서 사용하는 표준 스킬·커맨드 모음.",
        "version": "1.0.0"
    },
    "plugins": [
        {
            "name": "nga-proofread",
            "source": "./plugins/nga-proofread",
            "description": "NGA 컨설팅 톤(간결·MECE·면책 없음·실무 중심)으로 한국어 텍스트를 교정·다듬기.",
            "version": "0.1.0",
